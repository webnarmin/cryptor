{
    "name": "webnarmin/cryptor",
    "description": "Authenticated encryption helper with versioned payloads and legacy decrypt support.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "webnarmin\\Cryptor\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Alex",
            "email": "webnarmin@gmail.com"
        }
    ],
    "scripts": {
        "test": "phpunit -c phpunit.xml",
        "check": [
            "composer validate --strict",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
